{
  "configurations": [
    {
      "name": "Ubuntu AVR",
      "includePath": [
        "${workspaceFolder}/**",
        "/opt/microchip/avr-gcc/avr/include",
        "/opt/microchip/avr-gcc/avr/include/avr"
